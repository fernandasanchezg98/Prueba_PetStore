{
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^26.0.0",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "@faker-js/faker": "^10.5.0",
    "cypress": "^15.18.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "esbuild": "^0.28.1"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/*.js"
    ]
  },

  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:create": "cypress run --spec 'cypress/e2e/features/createUser.feature'",
    "test:edit": "cypress run --spec 'cypress/e2e/features/editUser.feature'",
    "test:get": "cypress run --spec 'cypress/e2e/features/getUser.feature'",
    "test:updated": "cypress run --spec 'cypress/e2e/features/getUpdatedUser.feature'",
    "test:delete": "cypress run --spec 'cypress/e2e/features/deleteUser.feature'",
    "test:all": "cypress run --spec 'cypress/e2e/features/*.feature'"
  }
}
